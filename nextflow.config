/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf/WGS-BACTERIAL NANOPORE CONFIG FILE
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments
----------------------------------------------------------------------------------------
    Author: Jimmy Lucas and Roger de Pedro Jové
    Description: Configuration for ONT Analysis
    Nextflow Version: >=25.10.0
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/


includeConfig 'conf/base.config'
includeConfig 'conf/process.config'
includeConfig 'conf/singularity.config'
includeConfig 'conf/docker.config'

// REPORTS
report {
    enabled   = true
    file      = "${params.outdir}/report/DVT_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.outdir}/report/DVT_timeline.html"
    overwrite = true
    dpi       = 100
}
trace {
    enabled   = true
    file      = "${params.outdir}/report/DVT_trace.txt"
    overwrite = true
    fields = 'task_id,process,name,attempt,status,exit,submit,start,duration,realtime,%cpu,%mem,peak_rss,peak_vmem,rchar,wchar'
}
dag {
    enabled   = true
    file      = "${params.outdir}/report/DVT_dag.svg"
    overwrite = true
}
workflow {
    summary = true
}
log {
    level = 'INFO'
}

