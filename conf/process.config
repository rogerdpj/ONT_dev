process {
    stageInMode = 'symlink'

    withLabel: 'env_kraken_db' {container = params.containers.kraken_db}
    withLabel: 'env_nanoplot' {container = params.containers.nanoplot}
    withLabel: 'env_trimming' {container = params.containers.trimming}
    withLabel: 'env_kraken' {container = params.containers.kraken}
    withLabel: 'env_seqtk' {container = params.containers.seqtk}
    withLabel: 'env_nanocomp' {container = params.containers.trimming}
    withLabel: 'env_flye' {container = params.containers.assembly}
    withLabel: 'env_polishing' {container = params.containers.assembly}
    withLabel: 'env_medaka' {container = params.containers.medaka}
    withLabel: 'env_dnaapler' {container = params.containers.assembly}
    withLabel: 'env_wrap' {container = params.containers.seqtk}
    withLabel: 'env_bakta' {container = params.containers.bakta}
    withLabel: 'env_quast' {container = params.containers.qc}
    withLabel: 'env_busco' {container = params.containers.qc}  
    withLabel: 'env_mosdepth' {container = params.containers.qc}
    withLabel: 'env_multiqc' {container = params.containers.qc}
    withLabel: 'env_abricate' {container = params.containers.post}
    withLabel: 'env_amrfinder' {container = params.containers.post}
    withLabel: 'env_mlst' {container = params.containers.post}
    withLabel: 'env_plasmid' {container = params.containers.post}
    
    withName: PREPARE_KRAKEN_DB {
        env {
            DB_SELECT = params.db_select ?: 'db_16GB'
            DB_DIR    = '/kraken2-db'
        }
    }
}